# ADAMAS configuration — copy to .env and adjust. All values are optional;
# the defaults shown are what ADAMAS uses if a variable is unset.

# --- Server ---
# Vault location (canonical Markdown + JSON live here).
ADAMAS_VAULT=./vault
# Bind host. 127.0.0.1 = local-only. Use 0.0.0.0 in a container.
ADAMAS_HOST=127.0.0.1
ADAMAS_PORT=8787
# Seed the 14-decision sample ledger on first boot if the vault is empty.
ADAMAS_SEED=0

# --- Optional HTTP basic auth (shared LAN / staging) ---
# Auth is OFF unless BOTH are set.
# ADAMAS_BASIC_USER=adamas
# ADAMAS_BASIC_PASS=clarity-audit

# --- Hermes (local evaluation agent) ---
# Which local provider backs Hermes:
#   local  = built-in deterministic heuristic (offline, no model needed) [default]
#   ollama = a local Ollama model (still on-device; nothing leaves the machine)
ADAMAS_HERMES_PROVIDER=local
# Ollama endpoint. On the host: http://127.0.0.1:11434
# From inside the Docker container, reach the host with host.docker.internal:
#   ADAMAS_OLLAMA_URL=http://host.docker.internal:11434
ADAMAS_OLLAMA_URL=http://127.0.0.1:11434
# Any model you've pulled with `ollama pull`, e.g. llama3.1, mistral, qwen2.5.
ADAMAS_OLLAMA_MODEL=llama3.1

# --- Read-only connectors ---
# Folder the local-folder connector reads (host path in Docker is ./sources).
ADAMAS_SOURCES_DIR=./vault/sources
