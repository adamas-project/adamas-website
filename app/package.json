{
  "name": "adamas",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "ADAMAS — local-first decision ledger. Captures the why behind decisions and generates business assets from them.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:web": "vite",
    "build": "tsc -p tsconfig.json && vite build",
    "build:server": "tsc -p tsconfig.json",
    "build:web": "vite build",
    "start": "node dist/index.js",
    "seed": "tsx src/seed/seed.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "ci": "bash scripts/ci.sh"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "fastify": "^5.8.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
